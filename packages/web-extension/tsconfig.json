{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": ".",
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo",
    "esModuleInterop": true,
    "incremental": true,
    "resolveJsonModule": true,
    "paths": {
      "~/*": [
        "src/*"
      ]
    },
    "jsx": "react-jsx"
  },
  "exclude": [
    "dist",
    "node_modules",
    "vite.config.ts"
  ],
  "references": [
    {
      "path": "../types"
    },
    {
      "path": "../rrweb"
    },
    {
      "path": "../rrweb-player"
    }
  ]
}
